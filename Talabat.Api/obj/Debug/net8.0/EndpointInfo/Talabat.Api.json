            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CustomerBasket": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Basket"
            },
            "nullable": true
          },
          "paymentIntentId": {
            "type": "string",
            "nullable": true
