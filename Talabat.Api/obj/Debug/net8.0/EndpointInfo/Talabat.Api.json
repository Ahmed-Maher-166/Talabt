            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "BasketItemDto": {
        "required": [
          "brand",
          "id",
          "pictureUrl",
          "price",
          "productName",
          "quantity",
          "type"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "productName": {
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "minimum": 0.1,
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "pictureUrl": {
            "minLength": 1,
            "type": "string"
          },
          "brand": {
            "minLength": 1,
            "type": "string"
          },
          "type": {
