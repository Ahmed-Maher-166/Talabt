        "type": "object",
        "properties": {
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BasketItemDto"
            },
            "nullable": true
          },
